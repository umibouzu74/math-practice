        "足して -17 → (負)+(負) しかない",
        "4 = 1×4 で、(x-4y)(4x-y) を確認"
      ],
      "solution": "(x-4y)(4x-y)",
      "steps": [
        "\\text{たすき掛け: } 1 \\times (-1) + 4 \\times (-4) = -1-16 = -17 \\;\\checkmark",
        "(x-4y)(4x-y)"
      ]
    },
    {
      "id": "fact-q04",
      "problem": "x^3+64 \\;\\text{を因数分解せよ}",
      "hints": [
        "64 = 4³ に気づく",
        "公式 a³+b³ = (a+b)(a²-ab+b²) を適用",
        "a=x, b=4"
      ],
      "solution": "(x+4)(x^2-4x+16)",
      "steps": [
        "x^3+4^3",
        "= (x+4)(x^2-x \\cdot 4+4^2)",
        "= (x+4)(x^2-4x+16)"
      ]
    },
    {
      "id": "fact-q05",
      "problem": "125x^3-27y^3 \\;\\text{を因数分解せよ}",
      "hints": [
        "125x³ = (5x)³、27y³ = (3y)³",
        "公式 a³-b³ = (a-b)(a²+ab+b²) を適用"
      ],
      "solution": "(5x-3y)(25x^2+15xy+9y^2)",
      "steps": [
        "(5x)^3-(3y)^3",
        "= (5x-3y)\\{(5x)^2+(5x)(3y)+(3y)^2\\}",
        "= (5x-3y)(25x^2+15xy+9y^2)"
      ]
    },
    {
      "id": "fact-q06",
      "problem": "8x^3-36x^2y+54xy^2-27y^3 \\;\\text{を因数分解せよ}",
      "hints": [
        "8x³=(2x)³、27y³=(3y)³ に着目",
