        "A^2-18A+45 = (A-3)(A-15)",
        "= (x^2-2x-3)(x^2-2x-15)",
        "= (x-3)(x+1)(x-5)(x+3)"
      ]
    },
    {
      "id": "fact-q10",
      "problem": "(x-1)(x-2)(x+3)(x+4)-24 \\;\\text{を因数分解せよ}",
      "hints": [
        "共通部分ができるように組み合わせる",
        "(-1)×(+4) = -4、(-2)×(+3) = -6 → (x+1)(x+4) と (x-2)(x+3) はダメ",
        "(-1)+(+3) = 2、(-2)+(+4) = 2 → (x-1)(x+3) と (x-2)(x+4) で共通部分 x²+2x を作る"
      ],
      "solution": "x(x+2)(x^2+2x-11)",
      "steps": [
        "(x-1)(x+3) = x^2+2x-3",
        "(x-2)(x+4) = x^2+2x-8",
        "A = x^2+2x \\text{ とおくと } (A-3)(A-8)-24",
        "= A^2-11A+24-24 = A^2-11A",
        "= A(A-11) = (x^2+2x)(x^2+2x-11)",
        "= x(x+2)(x^2+2x-11)"
      ]
    },
    {
      "id": "fact-q11",
      "problem": "4x^4-13x^2+3 \\;\\text{を因数分解せよ}",
