      "solution": "(x-3y+4)(2x+y-3)",
      "steps": [
        "x \\text{ で整理: } 2x^2+(-5y+5)x-(3y^2-13y+12)",
        "3y^2-13y+12 = (3y-4)(y-3)",
        "\\text{全体のたすき掛け: } 1 \\times (y-3) + 2 \\times \\{-(3y-4)\\} = y-3-6y+8 = -5y+5 \\;\\checkmark",
        "= \\{x-(3y-4)\\}\\{2x+(y-3)\\}",
        "= (x-3y+4)(2x+y-3)"
      ]
    }
  ]
}
