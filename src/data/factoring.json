  "problems": [
    {
      "id": "fact-q01",
      "problem": "2x^2+5x+3 \\;\\text{を因数分解せよ}",
      "hints": [
        "たすき掛けを使う",
        "x² の係数 2 = 1×2、定数項 3 = 1×3",
        "斜めの積の和: 1·3 + 2·1 = 5 ✓"
      ],
      "solution": "(x+1)(2x+3)",
      "steps": [
        "\\text{たすき掛け: } \\begin{array}{cc|c} 1 & 1 & \\to 2 \\\\ 2 & 3 & \\to 3 \\end{array} \\quad 2+3=5 \\;\\checkmark",
        "(x+1)(2x+3)"
      ]
    },
    {
      "id": "fact-q02",
      "problem": "8x^2-22x+15 \\;\\text{を因数分解せよ}",
      "hints": [
        "たすき掛けで x² の係数 8、定数項 15",
        "8 = 2×4、15 = 3×5",
        "符号: x の係数が負で定数項が正 → 両方負"
      ],
      "solution": "(2x-3)(4x-5)",
      "steps": [
        "\\text{たすき掛け: } 2 \\times (-5) + 4 \\times (-3) = -10-12 = -22 \\;\\checkmark",
