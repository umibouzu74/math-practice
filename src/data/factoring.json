{
  "id": "factoring",
  "formulas": [
    {
      "id": "fact-f01",
      "category": "因数分解公式[1]",
      "name": "和の2乗（因数分解）",
      "formula": "a^2+2ab+b^2 = (a+b)^2",
      "example": "4x^2+12xy+9y^2 = (2x+3y)^2",
      "note": "中学範囲。展開公式の逆"
    },
    {
      "id": "fact-f02",
      "category": "因数分解公式[1]",
      "name": "差の2乗（因数分解）",
      "formula": "a^2-2ab+b^2 = (a-b)^2",
      "example": "4x^2-12xy+9y^2 = (2x-3y)^2",
      "note": "中学範囲。展開公式の逆"
    },
    {
      "id": "fact-f03",
      "category": "因数分解公式[2]",
      "name": "2乗の差",
      "formula": "a^2-b^2 = (a+b)(a-b)",
      "example": "4x^2-9y^2 = (2x+3y)(2x-3y)",
      "note": "中学範囲。最も基本的な因数分解公式"
    },
    {
      "id": "fact-f04",
      "category": "因数分解公式[3]",
      "name": "和の3乗（因数分解）",
      "formula": "a^3+3a^2b+3ab^2+b^3 = (a+b)^3",
      "example": "x^3+6x^2+12x+8 = (x+2)^3",
      "note": "3次の項と定数項が3乗の形のとき疑う"
    },
    {
      "id": "fact-f05",
      "category": "因数分解公式[3]",
      "name": "差の3乗（因数分解）",
      "formula": "a^3-3a^2b+3ab^2-b^3 = (a-b)^3",
      "example": "8x^3-36x^2y+54xy^2-27y^3 = (2x-3y)^3",
      "note": "3次の項と定数項が3乗の形のとき疑う"
    },
    {
      "id": "fact-f06",
      "category": "因数分解公式[4]",
      "name": "3乗の和",
      "formula": "a^3+b^3 = (a+b)(a^2-ab+b^2)",
      "example": "x^3+64 = (x+4)(x^2-4x+16)",
      "note": "a²-ab+b² は実数範囲ではこれ以上因数分解できない"
    },
    {
      "id": "fact-f07",
      "category": "因数分解公式[4]",
      "name": "3乗の差",
      "formula": "a^3-b^3 = (a-b)(a^2+ab+b^2)",
      "example": "125x^3-27y^3 = (5x-3y)(25x^2+15xy+9y^2)",
      "note": "a²+ab+b² の符号は全て＋"
    },
    {
      "id": "fact-f08",
      "category": "因数分解公式",
      "name": "3変数の3乗の因数分解",
      "formula": "a^3+b^3+c^3-3abc = (a+b+c)(a^2+b^2+c^2-ab-bc-ca)",
      "example": "",
      "note": "暗記必須。a+b+c=0 ならば a³+b³+c³=3abc が成立"
    },
    {
      "id": "fact-f09",
      "category": "因数分解公式",
      "name": "a³+b³ の変形（対称式用）",
      "formula": "a^3+b^3 = (a+b)^3-3ab(a+b)",
      "example": "",
      "note": "展開公式 (a+b)³ を変形したもの。対称式でよく利用する"
    },
    {
      "id": "fact-f10",
      "category": "因数分解公式[5]",
      "name": "aⁿ-bⁿ の一般化",
      "formula": "a^n-b^n = (a-b)(a^{n-1}+a^{n-2}b+\\cdots+ab^{n-2}+b^{n-1})",
      "example": "a^4-b^4 = (a-b)(a^3+a^2b+ab^2+b^3)",
      "note": "n が偶数でも奇数でも成立。特に xⁿ-1=(x-1)(xⁿ⁻¹+xⁿ⁻²+…+x+1)"
    },
    {
      "id": "fact-f11",
      "category": "因数分解公式[5]",
      "name": "aⁿ+bⁿ の一般化（n が奇数）",
      "formula": "a^n+b^n = (a+b)(a^{n-1}-a^{n-2}b+\\cdots-ab^{n-2}+b^{n-1})",
      "example": "a^5+b^5 = (a+b)(a^4-a^3b+a^2b^2-ab^3+b^4)",
      "note": "n が奇数のときに限って成立。符号は交互"
    }
  ],
  "terms": [
    {
      "id": "fact-t01",
      "term": "因数分解",
      "definition": "整式を2つ以上の整式の積の形に変形すること。展開の逆操作"
    },
    {
      "id": "fact-t02",
      "term": "たすき掛け",
      "definition": "2次3項式 ax²+bx+c の因数分解で、ac=積, bd=積, ad+bc=和 の条件を表にして整数 a,b,c,d を求める方法"
    },
    {
      "id": "fact-t03",
      "term": "共通因数",
      "definition": "すべての項に共通する因数。因数分解では「共通因数をくくり出す」が常に最優先",
      "example": "16x^2+58xy-24y^2 = 2(8x^2+29xy-12y^2)"
    },
    {
      "id": "fact-t04",
      "term": "複2次式",
      "definition": "x⁴+bx²+c のような2乗の2次式。x²=A とおいてたすき掛けするか、(x²±○)²-(□x)² の形に変形する"
    },
    {
      "id": "fact-t05",
      "term": "2元2次6項式",
      "definition": "ax²+bxy+cy²+dx+ey+f の形の式。1つの文字で整理し、たすき掛けを2回行う"
    },
    {
      "id": "fact-t06",
      "term": "対称式",
      "definition": "2つの変数を入れ替えても変わらない式。因数分解後も対称式になる",
      "example": "x^2+y^2 \\;\\text{は対称式（x↔yで変わらない）}"
    },
    {
      "id": "fact-t07",
      "term": "交代式",
      "definition": "2つの変数を入れ替えると符号が逆になる式。差 (a-b) を因数にもつ",
      "example": "a^2(b-c)+b^2(c-a)+c^2(a-b)"
    },
    {
      "id": "fact-t08",
      "term": "輪環の順",
      "definition": "a→b→c→a の順に整理すること。3変数の対称式・交代式の答えを美しく書く方法"
    }
  ],
