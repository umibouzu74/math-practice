  "problems": [
    {
      "id": "poly-q01",
      "problem": "(2x-3)(4x-5) \\;\\text{を展開せよ}",
      "hints": [
        "公式 (ax+b)(cx+d) = acx²+(ad+bc)x+bd の形",
        "x の係数 = （外側の積）＋（内側の積）= 2·(-5)+(-3)·4"
      ],
      "solution": "8x^2-22x+15",
      "steps": [
        "2 \\cdot 4 \\cdot x^2 + \\{2 \\cdot(-5)+(-3) \\cdot 4\\}x + (-3)(-5)",
        "= 8x^2 + (-10-12)x + 15",
        "= 8x^2-22x+15"
      ]
    },
    {
      "id": "poly-q02",
      "problem": "(x+2)^3 \\;\\text{を展開せよ}",
      "hints": [
        "公式 (a+b)³ = a³+3a²b+3ab²+b³",
        "a=x, b=2 として代入"
      ],
      "solution": "x^3+6x^2+12x+8",
      "steps": [
        "x^3 + 3 \\cdot x^2 \\cdot 2 + 3 \\cdot x \\cdot 2^2 + 2^3",
        "= x^3+6x^2+12x+8"
      ]
    },
    {
      "id": "poly-q03",
      "problem": "(2x-3y)^3 \\;\\text{を展開せよ}",
      "hints": [
        "公式 (a-b)³ = a³-3a²b+3ab²-b³ で a=2x, b=3y",
        "または (a+b)³ で a=2x, b=-3y として代入しても可"
      ],
      "solution": "8x^3-36x^2y+54xy^2-27y^3",
      "steps": [
        "(2x)^3 - 3(2x)^2(3y) + 3(2x)(3y)^2 - (3y)^3",
        "= 8x^3 - 3 \\cdot 4x^2 \\cdot 3y + 3 \\cdot 2x \\cdot 9y^2 - 27y^3",
        "= 8x^3-36x^2y+54xy^2-27y^3"
      ]
    },
    {
      "id": "poly-q04",
      "problem": "(3x+y+2z)^2 \\;\\text{を展開せよ}",
      "hints": [
        "3項の2乗の公式を使う",
        "(a+b+c)² = a²+b²+c²+2ab+2bc+2ca",
        "a=3x, b=y, c=2z"
      ],
      "solution": "9x^2+y^2+4z^2+6xy+4yz+12zx",
      "steps": [
        "(3x)^2+y^2+(2z)^2+2(3x)y+2y(2z)+2(2z)(3x)",
        "= 9x^2+y^2+4z^2+6xy+4yz+12zx"
      ]
    },
    {
      "id": "poly-q05",
      "problem": "(x-2y-3z)^2 \\;\\text{を展開せよ}",
      "hints": [
        "3項の2乗の公式で a=x, b=-2y, c=-3z とおく",
        "負の符号に注意して2乗する"
      ],
      "solution": "x^2+4y^2+9z^2-4xy+12yz-6zx",
      "steps": [
        "x^2+(-2y)^2+(-3z)^2+2 \\cdot x(-2y)+2(-2y)(-3z)+2(-3z) \\cdot x",
        "= x^2+4y^2+9z^2-4xy+12yz-6zx"
      ]
    },
    {
      "id": "poly-q06",
      "problem": "(x^2-x+3)^2 \\;\\text{を展開せよ}",
      "hints": [
        "3項の2乗の公式で a=x², b=-x, c=3",
        "展開後、同類項をまとめて降べきの順に整理する"
      ],
      "solution": "x^4-2x^3+7x^2-6x+9",
      "steps": [
        "(x^2)^2+(-x)^2+3^2+2 \\cdot x^2(-x)+2(-x) \\cdot 3+2 \\cdot 3 \\cdot x^2",
        "= x^4+x^2+9-2x^3-6x+6x^2",
        "= x^4-2x^3+7x^2-6x+9"
      ]
    },
    {
      "id": "poly-q07",
      "problem": "(x+2)(x^2-2x+4) \\;\\text{を展開せよ}",
      "hints": [
        "公式 (a+b)(a²-ab+b²)=a³+b³ の形ではないか確認",
        "a=x, b=2 とすると a²-ab+b² = x²-2x+4 で一致"
      ],
      "solution": "x^3+8",
      "steps": [
        "\\text{公式 } (a+b)(a^2-ab+b^2) = a^3+b^3 \\text{ の形}",
        "a=x,\\; b=2 \\text{ より}",
        "= x^3+2^3 = x^3+8"
      ]
    },
    {
      "id": "poly-q08",
      "problem": "(2x-3y)(4x^2+6xy+9y^2) \\;\\text{を展開せよ}",
      "hints": [
        "公式 (a-b)(a²+ab+b²)=a³-b³ の形ではないか確認",
        "a=2x, b=3y として確認: a²=4x², ab=6xy, b²=9y²"
      ],
      "solution": "8x^3-27y^3",
      "steps": [
