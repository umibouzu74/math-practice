      "explanation": "(x-y)²=64-4=60。2乗をはずすとき ±√60 となるが、x>y か x<y かを判断する必要がある"
    },
    {
      "id": "real-p05",
      "problem": "x^2-5x+1=0 \\;\\text{のとき}\\; x+\\frac{1}{x}",
      "prompt": "x+1/x の値を求める最も簡潔な方法は？",
      "correct": "x≠0 を確認し、両辺を x で割る",
      "options": ["解の公式で x を求めてから代入", "x≠0 を確認し、両辺を x で割る", "対称式の公式を使う", "因数分解する"],
      "explanation": "x≠0（代入して確認可）なので両辺を x で割ると x-5+1/x=0 → x+1/x=5。以降 x²+1/x²=(x+1/x)²-2=23 などと展開できる"
    },
    {
      "id": "real-p06",
      "problem": "\\frac{3}{\\sqrt{7}-2}",
      "prompt": "整数部分と小数部分を求めるための最初の一手は？",
      "correct": "有理化して整数部分を求めやすい形にする",
      "options": ["近似値で計算", "有理化して整数部分を求めやすい形にする", "2乗して考える", "不等式で直接評価"],
      "explanation": "有理化: 3(√7+2)/(7-4) = √7+2。4<7<9 より 2<√7<3 → 4<√7+2<5。整数部分は4、小数部分は √7-2"
    }
  ],
  "problems": [
    {
      "id": "real-q01",
      "problem": "|3\\sqrt{7}-8| \\;\\text{の絶対値をはずせ}",
      "hints": [
        "3√7 と 8 の大小を比較する",
        "√○ の形に揃える: 3√7=√63, 8=√64",
        "√63 < √64 だから 3√7 < 8"
      ],
      "solution": "8-3\\sqrt{7}",
      "steps": [
        "3\\sqrt{7}=\\sqrt{63},\\quad 8=\\sqrt{64}",
        "\\sqrt{63}<\\sqrt{64} \\;\\text{より}\\; 3\\sqrt{7}-8<0",
        "\\therefore |3\\sqrt{7}-8| = -(3\\sqrt{7}-8) = 8-3\\sqrt{7}"
      ]
    },
    {
      "id": "real-q02",
      "problem": "|\\pi-4|+|3-\\pi| \\;\\text{の絶対値をはずせ}",
      "hints": [
        "π ≈ 3.14 より各中身の正負を判断",
        "π-4 < 0（負）、3-π < 0（負）"
      ],
      "solution": "1",
      "steps": [
        "\\pi < 4 \\;\\text{より}\\; |\\pi-4| = -(\\pi-4) = 4-\\pi",
        "\\pi > 3 \\;\\text{より}\\; |3-\\pi| = -(3-\\pi) = \\pi-3",
        "\\therefore (4-\\pi)+(\\pi-3) = 1"
      ]
    },
    {
      "id": "real-q03",
      "problem": "\\sqrt{5+2\\sqrt{6}} \\;\\text{の2重根号をはずせ}",
      "hints": [
        "根号の前はすでに2",
        "和が5、積が6となる自然数を探す",
        "3+2=5, 3×2=6 → a=3, b=2"
      ],
      "solution": "\\sqrt{3}+\\sqrt{2}",
      "steps": [
        "\\text{和が5, 積が6} \\to a=3,\\; b=2",
        "\\sqrt{5+2\\sqrt{6}} = \\sqrt{(\\sqrt{3}+\\sqrt{2})^2} = \\sqrt{3}+\\sqrt{2}"
      ]
    },
    {
      "id": "real-q04",
      "problem": "\\sqrt{6-\\sqrt{32}} \\;\\text{の2重根号をはずせ}",
      "hints": [
        "まず根号の前を2にする: √32 = √(4·8) = 2√8",
        "和が6、積が8となる自然数を探す",
        "4+2=6, 4×2=8。常に a>b とする"
      ],
      "solution": "2-\\sqrt{2}",
      "steps": [
        "\\sqrt{32} = 2\\sqrt{8}",
        "\\sqrt{6-2\\sqrt{8}} = \\sqrt{(\\sqrt{4}-\\sqrt{2})^2}",
        "= \\sqrt{4}-\\sqrt{2} = 2-\\sqrt{2}"
      ]
    },
    {
      "id": "real-q05",
      "problem": "\\sqrt{11+4\\sqrt{7}} \\;\\text{の2重根号をはずせ}",
      "hints": [
        "4 のうち2だけ残して根号内に入れる: 4√7 = 2·2√7 = 2√28",
        "和が11、積が28となる自然数を探す",
        "7+4=11, 7×4=28"
      ],
      "solution": "\\sqrt{7}+2",
      "steps": [
        "4\\sqrt{7} = 2\\sqrt{28}",
        "\\sqrt{11+2\\sqrt{28}} = \\sqrt{(\\sqrt{7}+\\sqrt{4})^2}",
        "= \\sqrt{7}+\\sqrt{4} = \\sqrt{7}+2"
      ]
    },
    {
      "id": "real-q06",
      "problem": "\\frac{\\sqrt{3}}{\\sqrt{7}+\\sqrt{2}} \\;\\text{の分母を有理化せよ}",
      "hints": [
        "分母分子に √7-√2 を掛ける",
        "(√7+√2)(√7-√2) = 7-2 = 5"
      ],
      "solution": "\\frac{\\sqrt{21}-\\sqrt{6}}{5}",
      "steps": [
        "\\frac{\\sqrt{3}(\\sqrt{7}-\\sqrt{2})}{(\\sqrt{7}+\\sqrt{2})(\\sqrt{7}-\\sqrt{2})}",
        "= \\frac{\\sqrt{21}-\\sqrt{6}}{7-2}",
        "= \\frac{\\sqrt{21}-\\sqrt{6}}{5}"
      ]
    },
    {
      "id": "real-q07",
      "problem": "\\frac{9}{\\sqrt{6}-\\sqrt{3}} \\;\\text{の分母を有理化せよ}",
      "hints": [
        "分母分子に √6+√3 を掛ける",
        "(√6-√3)(√6+√3) = 6-3 = 3",
        "約分できる場合は約分してから展開する"
      ],
      "solution": "3\\sqrt{6}+3\\sqrt{3}",
      "steps": [
        "\\frac{9(\\sqrt{6}+\\sqrt{3})}{(\\sqrt{6}-\\sqrt{3})(\\sqrt{6}+\\sqrt{3})}",
        "= \\frac{9(\\sqrt{6}+\\sqrt{3})}{3}",
        "= 3(\\sqrt{6}+\\sqrt{3}) = 3\\sqrt{6}+3\\sqrt{3}"
      ]
    },
    {
      "id": "real-q08",
      "problem": "0.\\dot{4} \\;\\text{を分数で表せ}",
      "hints": [
        "x = 0.4444… とおく",
        "10x = 4.4444…",
        "10x - x = 4"
      ],
      "solution": "\\frac{4}{9}",
      "steps": [
        "x = 0.\\dot{4} \\text{ とおく}",
        "10x = 4.4444\\cdots",
        "10x - x = 4 \\;\\text{より}\\; 9x = 4",
        "\\therefore x = \\frac{4}{9}"
      ]
    },
    {
      "id": "real-q09",
      "problem": "x+y=8,\\; xy=1 \\;\\text{のとき}\\; x^2+y^2,\\; x^3+y^3 \\;\\text{の値を求めよ}",
      "hints": [
        "x²+y² = (x+y)²-2xy を使う",
        "x³+y³ = (x+y)³-3xy(x+y) を使う"
      ],
      "solution": "x^2+y^2=62,\\quad x^3+y^3=488",
      "steps": [
        "x^2+y^2 = (x+y)^2-2xy = 8^2-2 \\cdot 1 = 62",
        "x^3+y^3 = (x+y)^3-3xy(x+y) = 8^3-3 \\cdot 1 \\cdot 8 = 488"
      ]
    },
    {
      "id": "real-q10",
      "problem": "\\frac{3}{\\sqrt{7}-2} \\;\\text{の整数部分を } a\\text{, 小数部分を } b \\;\\text{とするとき}\\; ab+b^2 \\;\\text{の値を求めよ}",
      "hints": [
        "まず有理化して √7+2 にする",
        "4<7<9 より 2<√7<3 → 4<√7+2<5",
        "整数部分 a=4、小数部分 b=√7-2",
        "式を因数分解してから代入すると楽"
      ],
      "solution": "3",
      "steps": [
        "\\frac{3}{\\sqrt{7}-2} = \\frac{3(\\sqrt{7}+2)}{3} = \\sqrt{7}+2",
        "4<7<9 \\;\\text{より}\\; 2<\\sqrt{7}<3 \\;\\text{→}\\; 4<\\sqrt{7}+2<5",
        "a=4,\\quad b=(\\sqrt{7}+2)-4 = \\sqrt{7}-2",
        "ab+b^2 = b(a+b) = (\\sqrt{7}-2)(4+\\sqrt{7}-2) = (\\sqrt{7}-2)(\\sqrt{7}+2) = 7-4 = 3"
      ]
    }
  ]
}
