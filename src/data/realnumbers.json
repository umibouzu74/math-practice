{
  "id": "realnumbers",
  "formulas": [
    {
      "id": "real-f01",
      "category": "平方根",
      "name": "2乗の平方根",
      "formula": "\\sqrt{a^2} = |a|",
      "example": "\\sqrt{3^2}=3,\\quad \\sqrt{(-3)^2}=|-3|=3",
      "note": "2乗の平方根は一旦絶対値をつけてはずす！ √a²=a とする誤りが非常に多い"
    },
    {
      "id": "real-f02",
      "category": "平方根",
      "name": "分母の有理化（基本）",
      "formula": "\\frac{1}{\\sqrt{a}\\pm\\sqrt{b}} = \\frac{\\sqrt{a}\\mp\\sqrt{b}}{a-b}",
      "example": "\\frac{\\sqrt{3}}{\\sqrt{7}+\\sqrt{2}} = \\frac{\\sqrt{21}-\\sqrt{6}}{5}",
      "note": "(√a+√b)(√a-√b) = a-b を利用。分母分子に √a∓√b を掛ける"
    },
    {
      "id": "real-f03",
      "category": "平方根",
      "name": "2重根号のはずし方",
      "formula": "\\sqrt{(a+b)\\pm 2\\sqrt{ab}} = \\sqrt{a}\\pm\\sqrt{b} \\quad (a>b>0)",
      "example": "\\sqrt{5+2\\sqrt{6}} = \\sqrt{3}+\\sqrt{2}",
      "note": "[1] 根号の前を2にする [2] 和が○、積が△の a,b を探す。常に a>b とする癖をつける"
    },
    {
      "id": "real-f04",
      "category": "循環小数",
      "name": "分数が割り切れる条件",
      "formula": "\\text{分母の素因数が 2 と 5 のみ}",
      "example": "\\frac{15}{8} = 1.875 \\quad (8=2^3)",
      "note": "割り切れない場合は循環小数になる。循環小数→分数は x とおいて 10ⁿ 倍して引く"
    },
    {
      "id": "real-f05",
      "category": "対称式",
      "name": "x²+y² の変形",
      "formula": "x^2+y^2 = (x+y)^2-2xy",
      "example": "",
      "note": "超頻出。基本対称式 x+y, xy で表す最も基本的な公式"
    },
    {
      "id": "real-f06",
      "category": "対称式",
      "name": "x³+y³ の変形",
      "formula": "x^3+y^3 = (x+y)^3-3xy(x+y)",
      "example": "",
      "note": "暗記必須。因数分解公式 (x+y)(x²-xy+y²) でも求まる"
    },
    {
      "id": "real-f07",
      "category": "対称式",
      "name": "x²+y²+z² の変形",
      "formula": "x^2+y^2+z^2 = (x+y+z)^2-2(xy+yz+zx)",
      "example": "",
      "note": "3変数の基本対称式 x+y+z, xy+yz+zx で表す"
    },
    {
      "id": "real-f08",
      "category": "対称式",
      "name": "x³+y³+z³ の変形",
      "formula": "x^3+y^3+z^3 = (x+y+z)(x^2+y^2+z^2-xy-yz-zx)+3xyz",
      "example": "",
      "note": "高校数学で最も覚えにくい公式の1つ。因数分解公式として覚える"
    },
    {
      "id": "real-f09",
      "category": "対称式",
      "name": "x²+1/x² の変形",
      "formula": "x^2+\\frac{1}{x^2} = \\left(x+\\frac{1}{x}\\right)^2-2",
      "example": "",
      "note": "x と 1/x の対称式は x+1/x のみで表される（x·1/x=1 より）"
    },
    {
      "id": "real-f10",
      "category": "対称式",
      "name": "x³+1/x³ の変形",
      "formula": "x^3+\\frac{1}{x^3} = \\left(x+\\frac{1}{x}\\right)^3-3\\left(x+\\frac{1}{x}\\right)",
      "example": "",
      "note": "x+1/x の値さえ求まれば全て計算できる"
    },
    {
      "id": "real-f11",
      "category": "対称式",
      "name": "xⁿ⁺²+yⁿ⁺² の漸化式",
      "formula": "x^{n+2}+y^{n+2} = (x^{n+1}+y^{n+1})(x+y)-xy(x^n+y^n)",
      "example": "",
      "note": "上級者用。低次の対称式から順に高次を求めていける一般化公式"
    },
    {
      "id": "real-f12",
      "category": "交代式",
      "name": "交代式の2乗は対称式",
      "formula": "|x-y| = \\sqrt{(x-y)^2} = \\sqrt{(x+y)^2-4xy}",
      "example": "",
      "note": "交代式は2乗すると対称式になる。基本対称式で表せる"
    },
    {
      "id": "real-f13",
      "category": "整数部分・小数部分",
      "name": "整数部分と小数部分",
      "formula": "\\text{（元の数）}= \\text{（整数部分 } a\\text{）}+\\text{（小数部分 } b\\text{）}\\quad (0 \\leq b < 1)",
      "example": "5.2 = 5+0.2,\\quad -2.4 = -3+0.6",
      "note": "整数部分は不等式で評価する。近似値で判断するのは危険"
    }
  ],
  "terms": [
    {
      "id": "real-t01",
      "term": "平方根",
      "definition": "正の数 a に対し、2乗すると a になる数。正の方を √a、負の方を -√a で表す。0の平方根は0のみ"
    },
    {
      "id": "real-t02",
      "term": "絶対値",
      "definition": "数直線上で原点からの距離。a≧0 のとき |a|=a、a<0 のとき |a|=-a。常に |a|≧0",
      "example": "|3|=3,\\quad |-3|=3"
    },
    {
      "id": "real-t03",
      "term": "有理化",
      "definition": "分母の根号（無理数）をなくすこと。(√a+√b)(√a-√b)=a-b を利用する"
    },
    {
      "id": "real-t04",
      "term": "2重根号",
      "definition": "根号の中に根号がある式。√(○±2√△) の形で、和が○、積が△の2数を探してはずす",
      "example": "\\sqrt{5+2\\sqrt{6}} = \\sqrt{3}+\\sqrt{2}"
    },
    {
      "id": "real-t05",
      "term": "循環小数",
      "definition": "同じ数字の並びが無限に繰り返される小数。循環部分の最初と最後の数字の上に・をつけて表す",
      "example": "\\frac{2}{9} = 0.\\dot{2},\\quad \\frac{5}{7} = 0.\\dot{7}1428\\dot{5}"
    },
    {
      "id": "real-t06",
      "term": "対称式（2変数）",
      "definition": "2つの変数を入れ替えても変わらない式。f(x,y)=f(y,x) が成立する",
      "example": "x^3+xy+y^3"
    },
    {
      "id": "real-t07",
      "term": "対称式（3変数）",
      "definition": "3変数のうちどの2つを入れ替えても変わらない式",
      "example": "x^2+y^2+z^2+xyz"
    },
    {
      "id": "real-t08",
      "term": "交代式（2変数）",
      "definition": "2つの変数を入れ替えると符号が逆になる式。f(x,y)=-f(y,x)。必ず差 (x-y) を因数にもつ",
      "example": "x^3-y^3 = (x-y)(x^2+xy+y^2)"
    },
    {
      "id": "real-t09",
      "term": "交代式（3変数）",
      "definition": "3変数のうちどの2つを入れ替えても符号が逆になる式。差積 (a-b)(b-c)(c-a) を因数にもつ"
    },
    {
      "id": "real-t10",
      "term": "基本対称式",
      "definition": "全ての対称式を表せる最小の対称式のセット。2変数: x+y, xy。3変数: x+y+z, xy+yz+zx, xyz"
    },
    {
      "id": "real-t11",
      "term": "対称式の基本定理",
      "definition": "全ての対称式は基本対称式のみで一意に表される、という定理"
    },
    {
      "id": "real-t12",
      "term": "整数部分",
      "definition": "実数を（整数）＋（小数部分）で表したときの整数部分。不等式で評価して求める"
    },
    {
      "id": "real-t13",
      "term": "小数部分",
      "definition": "（元の数）−（整数部分）で求まる。0以上1未満の値をとる"
    }
  ],
  "patterns": [
    {
      "id": "real-p01",
      "problem": "\\sqrt{x^2-4x+4}+\\sqrt{9x^2+6x+1}",
      "prompt": "この式を簡単にする最初の一手は？",
      "correct": "因数分解して2乗の形にし、√a²=|a| を使う",
      "options": ["そのまま近似値で計算", "因数分解して2乗の形にし、√a²=|a| を使う", "2乗して根号をはずす", "有理化する"],
      "explanation": "x²-4x+4=(x-2)², 9x²+6x+1=(3x+1)²。よって |x-2|+|3x+1| となり、場合分けして絶対値をはずす問題に帰着する"
    },
    {
